  <script data-ai-id="scr-crsh10" id="scr-crsh10">
   (function() {
  const section = document.getElementById('sec-crsh10');
  if (!section) return;

  function processHeading() {
    const headingElement = document.getElementById('el-crsh10e');
    if (!headingElement) return;

    const text = headingElement.textContent.trim();
    const words = text.split(/\s+/);
    const wordCount = words.length;

    let highlightIndices = [];
    let accentStartIndex = -1;

    if (wordCount === 1) {
      highlightIndices = [0];
    } else if (wordCount <= 3) {
      highlightIndices = [0];
      accentStartIndex = wordCount - 1;
    } else {
      highlightIndices = [Math.floor(wordCount / 2)];
      accentStartIndex = wordCount - 2;
    }

    const processedWords = words.map((word, index) => {
      if (highlightIndices.includes(index)) {
        return `<span class="hero10-highlight">${word}</span>`;
      }
      return word;
    });

    let resultHTML = processedWords.join(' ');
    
    if (accentStartIndex >= 0 && accentStartIndex < wordCount) {
      const accentedWords = processedWords.slice(accentStartIndex).join(' ');
      const firstPart = processedWords.slice(0, accentStartIndex).join(' ');
      resultHTML = firstPart + (firstPart ? ' ' : '') + `<span class="hero10-accent">${accentedWords}</span>`;
    }

    headingElement.innerHTML = resultHTML;
  }

  function setupScrollButton() {
    const button = section.querySelector('[data-cta-type="scroll_buy_now"]');
    if (!button) return;

    button.addEventListener('click', function(e) {
      e.preventDefault();
      const plansSection = document.getElementById('sec-p9k2m4x7');
      if (plansSection) {
        plansSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        console.warn('Course plans section not found');
      }
    });

    button.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        this.click();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      processHeading();
      setupScrollButton();
    });
  } else {
    processHeading();
    setupScrollButton();
  }
})();
